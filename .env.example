APOLLO_API_KEY=
# Keep on for repeated Apollo lookups; disable if you only want mock fallback
APOLLO_CACHE_ENABLED=true
# Optional: custom cache directory or file for Apollo enrichment cache
# APOLLO_CACHE_DIR=.cache
# APOLLO_CACHE_PATH=.cache/apollo-company-enrichment.json
LOGOKIT_API_KEY=
MARKSTER_API_BASE_URL=https://panel.markster.io
# Required for live Markster mode
MARKSTER_CUSTOMER_API_KEY=
# Optional fallback aliases (legacy/local)
MARKSTER_CUSTOMER_TOKEN=
MARKSTER_DOCS_API_KEY=
# Optional explicit local mode only:
MARKSTER_MOCK_MODE=false

# Optional WorkOS auth (safe canary path)
# Existing MCP endpoint stays open at /mcp
# Auth-gated endpoint: /mcp-auth
WORKOS_AUTH_ENABLED=false
WORKOS_OAUTH_DISCOVERY_ENABLED=false
WORKOS_AUTH_REQUIRED=false
WORKOS_AUTH_REPORT_ONLY=true
WORKOS_AUTH_VERIFY_JWT=false
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=
WORKOS_COOKIE_PASSWORD=
# Optional OAuth overrides
# WORKOS_OAUTH_ISSUER=https://api.workos.com
# WORKOS_OAUTH_AUDIENCE=
# WORKOS_OAUTH_SCOPES=openid profile email offline
# WORKOS_JWKS_URI=
# MCP_PUBLIC_BASE_URL=https://dealpulse-prod.hackathon.markster.io
