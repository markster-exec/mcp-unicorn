{
  "name": "dealpulse-mcp-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "lint": "node -e \"console.log('lint: temporary passthrough while ESLint config is not present; see package.json scripts')\"",
    "openapi:generate": "tsx scripts/generate-markster-openapi-schemas.ts",
    "openapi:check": "npm run openapi:generate && git diff --quiet -- src/markster/generated-openapi-schemas.ts",
    "mcp:test": "tsx scripts/mcp-test-cli.ts",
    "mcp:test:check": "tsx scripts/mcp-test-cli.ts check",
    "mcp:test:walkthrough": "tsx scripts/mcp-test-cli.ts walkthrough",
    "headshots:flux2": "node scripts/generate-headshots-flux2.mjs",
    "build": "cross-env INPUT=resources/app.html vite build",
    "start": "npm run build && tsx main.ts",
    "serve": "tsx main.ts",
    "dev": "cross-env NODE_ENV=development INPUT=resources/app.html vite build --watch & npx tsx watch main.ts",
    "inspect": "npm run build",
    "deploy": "mcp-use deploy"
  },
  "dependencies": {
    "@mcp-use/cli": "^2.13.5",
    "@modelcontextprotocol/ext-apps": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.19.3",
    "@workos-inc/node": "^8.5.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.0.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^24.0.4",
    "cross-env": "^10.1.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-singlefile": "^2.1.2"
  }
}
